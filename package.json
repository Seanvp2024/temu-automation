{
  "name": "temu-automation",
  "private": true,
  "version": "0.1.85",
  "type": "module",
  "main": "electron/main.cjs",
  "scripts": {
    "dev": "concurrently \"vite\" \"wait-on http://localhost:1420 && cross-env NODE_ENV=development electron .\"",
    "dev:web": "vite",
    "dev:electron": "concurrently \"vite\" \"wait-on http://localhost:1420 && cross-env NODE_ENV=development electron .\"",
    "build:resources": "python scripts/generate_brand_assets.py",
    "build:node-runtime": "node scripts/prepare-node-runtime.cjs",
    "build:image-studio": "python scripts/prepare_image_studio_bundle.py",
    "prepare:update-site": "python scripts/prepare_static_update_site.py",
    "verify:data-contracts": "node --experimental-strip-types scripts/verify-data-contracts.ts",
    "test:desktop": "node scripts/test-desktop-regression.cjs",
    "verify:release": "npm run verify:data-contracts && npm run build:node-runtime && node scripts/verify-release-prereqs.cjs",
    "smoke:desktop": "node scripts/smoke-desktop.cjs",
    "build": "tsc && vite build --base ./",
    "dist:win": "npm run build:resources && npm run build:node-runtime && npm run build:image-studio && npm run verify:release && npm run build && npm run smoke:desktop && electron-builder --win nsis",
    "pack:win": "npm run build:resources && npm run build:node-runtime && npm run build:image-studio && npm run verify:release && npm run build && npm run smoke:desktop && electron-builder --win dir",
    "preview": "vite preview",
    "electron": "cross-env NODE_ENV=development electron ."
  },
  "build": {
    "appId": "com.temu.automation",
    "productName": "Temu 自动化运营工具",
    "asar": true,
    "directories": {
      "output": "release",
      "buildResources": "build"
    },
    "extraResources": [
      {
        "from": "build/node-runtime",
        "to": "node-runtime"
      },
      {
        "from": "build/auto-image-gen-runtime",
        "to": "auto-image-gen-runtime"
      }
    ],
    "files": [
      "electron/**/*",
      "automation/**/*",
      "node_modules/**/*",
      "package.json",
      "!src/**/*",
      "!docs/**/*",
      "!*.log",
      "!test_*.json"
    ],
    "extraFiles": [
      {
        "from": "dist",
        "to": "dist"
      }
    ],
    "win": {
      "target": [
        {
          "target": "nsis",
          "arch": [
            "x64"
          ]
        }
      ],
      "icon": "build/icon.ico",
      "signAndEditExecutable": false,
      "artifactName": "temu-automation-setup-${version}.${ext}"
    },
    "nsis": {
      "oneClick": false,
      "allowToChangeInstallationDirectory": true,
      "createDesktopShortcut": true,
      "createStartMenuShortcut": true,
      "shortcutName": "Temu 自动化运营工具"
    }
  },
  "dependencies": {
    "@ant-design/icons": "^5.4.0",
    "antd": "^5.20.0",
    "better-sqlite3": "^12.8.0",
    "concurrently": "^9.2.1",
    "dayjs": "^1.11.12",
    "electron-store": "^11.0.2",
    "electron-updater": "^6.8.3",
    "playwright": "^1.58.2",
    "react": "^18.3.1",
    "react-dom": "^18.3.1",
    "react-router-dom": "^6.26.0",
    "recharts": "^2.12.7",
    "undici": "^8.1.0",
    "wait-on": "^9.0.4",
    "xlsx": "^0.18.5",
    "zustand": "^4.5.4"
  },
  "devDependencies": {
    "@types/react": "^18.3.3",
    "@types/react-dom": "^18.3.0",
    "@vitejs/plugin-react": "^4.3.1",
    "cross-env": "^10.1.0",
    "electron": "^41.0.3",
    "electron-builder": "^26.8.1",
    "typescript": "^5.5.3",
    "vite": "^5.4.0"
  }
}
