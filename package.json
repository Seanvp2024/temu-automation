{
  "name": "temu-automation",
  "private": true,
  "version": "0.1.19",
  "type": "module",
  "main": "electron/main.cjs",
  "scripts": {
    "dev": "vite",
    "dev:electron": "concurrently \"vite\" \"wait-on http://localhost:1420 && cross-env NODE_ENV=development electron .\"",
    "build": "tsc && vite build --base ./",
    "dist:win": "npm run build && electron-builder --win nsis",
    "pack:win": "npm run build && electron-builder --win dir",
    "preview": "vite preview",
    "electron": "cross-env NODE_ENV=development electron .",
    "tauri": "tauri"
  },
  "build": {
    "appId": "com.temu.automation",
    "productName": "Temu 自动化运营工具",
    "asar": true,
    "directories": {
      "output": "release",
      "buildResources": "build"
    },
    "extraResources": [
      {
        "from": "C:/New Folder/node.exe",
        "to": "node-runtime/node.exe"
      },
      {
        "from": "build/auto-image-gen-runtime",
        "to": "auto-image-gen-runtime"
      }
    ],
    "files": [
      "dist/**/*",
      "electron/**/*",
      "automation/**/*",
      "node_modules/**/*",
      "package.json",
      "!src/**/*",
      "!src-tauri/**/*",
      "!docs/**/*",
      "!*.log",
      "!test_*.json"
    ],
    "win": {
      "target": [{ "target": "nsis", "arch": ["x64"] }],
      "icon": "build/icon.ico",
      "signAndEditExecutable": false,
      "artifactName": "temu-automation-setup-${version}.${ext}"
    },
    "nsis": {
      "oneClick": false,
      "allowToChangeInstallationDirectory": true,
      "createDesktopShortcut": true,
      "createStartMenuShortcut": true,
      "shortcutName": "Temu 自动化运营工具"
    }
  },
  "dependencies": {
    "@ant-design/icons": "^5.4.0",
    "antd": "^5.20.0",
    "better-sqlite3": "^12.8.0",
    "concurrently": "^9.2.1",
    "dayjs": "^1.11.12",
    "electron-store": "^11.0.2",
    "playwright": "^1.58.2",
    "react": "^18.3.1",
    "react-dom": "^18.3.1",
    "react-router-dom": "^6.26.0",
    "recharts": "^2.12.7",
    "wait-on": "^9.0.4",
    "xlsx": "^0.18.5",
    "zustand": "^4.5.4"
  },
  "devDependencies": {
    "@tauri-apps/api": "^2.0.0",
    "@tauri-apps/cli": "^2.0.0",
    "@types/react": "^18.3.3",
    "@types/react-dom": "^18.3.0",
    "@vitejs/plugin-react": "^4.3.1",
    "cross-env": "^10.1.0",
    "electron": "^41.0.3",
    "electron-builder": "^26.8.1",
    "typescript": "^5.5.3",
    "vite": "^5.4.0"
  }
}
